{
  "name": "slate-demo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build && node scripts/strip-build-redirects.mjs",
    "preview": "vite preview --host 0.0.0.0",
    "static": "node scripts/spa-static-server.mjs",
    "preview:static": "npm run build && npm run static",
    "start": "npm run static",
    "check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "3.0.10",
    "@sveltejs/kit": "2.59.1",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@tailwindcss/vite": "4.3.0",
    "@types/node": "^25.6.2",
    "svelte": "5.55.5",
    "svelte-check": "4.4.8",
    "tailwindcss": "4.3.0",
    "vite": "8.0.11"
  }
}
